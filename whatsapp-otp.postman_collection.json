{
  "info": {
    "name": "Hevis WhatsApp App APIs",
    "_postman_id": "a8c3f1e2-4b9d-4a1c-9f2e-whatsapp-otp-hevis",
    "description": "Next.js app APIs only (`hevis/whatsapp`).\n\nRun locally: `npm run dev` → `{{baseUrl}}`",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "mobile",
      "value": "9876543210"
    },
    {
      "key": "otp",
      "value": "123456"
    }
  ],
  "item": [
    {
      "name": "Send OTP",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"mobile\": \"{{mobile}}\",\n  \"otp\": \"{{otp}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/send-otp",
          "host": ["{{baseUrl}}"],
          "path": ["api", "send-otp"]
        },
        "description": "Sends a 6-digit OTP to the given mobile via WhatsApp. OTP must be provided in the request.\n\n**Response:** `{ \"success\": true }`"
      },
      "response": []
    },
    {
      "name": "WhatsApp Webhook",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"object\": \"whatsapp_business_account\",\n  \"entry\": [\n    {\n      \"id\": \"123456789\",\n      \"changes\": [\n        {\n          \"value\": {\n            \"messaging_product\": \"whatsapp\",\n            \"metadata\": {\n              \"display_phone_number\": \"15550000000\",\n              \"phone_number_id\": \"123456789\"\n            },\n            \"messages\": [\n              {\n                \"from\": \"919876543210\",\n                \"id\": \"wamid.test\",\n                \"timestamp\": \"1710000000\",\n                \"type\": \"text\",\n                \"text\": {\n                  \"body\": \"Hello\"\n                }\n              }\n            ]\n          },\n          \"field\": \"messages\"\n        }\n      ]\n    }\n  ]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/whatsapp/webhook",
          "host": ["{{baseUrl}}"],
          "path": ["api", "whatsapp", "webhook"]
        },
        "description": "Receives WhatsApp webhook payload and saves it to MySQL `webhook_logs` table.\n\n**Response:** `{ \"success\": true, \"id\": <insertId> }`"
      },
      "response": []
    },
    {
      "name": "List Webhook Logs",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/webhook-logs?limit=50",
          "host": ["{{baseUrl}}"],
          "path": ["api", "webhook-logs"],
          "query": [
            {
              "key": "limit",
              "value": "50",
              "description": "Max 100"
            }
          ]
        },
        "description": "Returns saved webhook payloads from the database (parsed JSON).\n\n**Response:** `{ \"success\": true, \"logs\": [...] }`"
      },
      "response": []
    }
  ]
}
